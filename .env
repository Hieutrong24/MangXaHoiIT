# ==================================================
# GLOBAL
# ==================================================
APP_NAME=it-social-platform
APP_ENV=development
NODE_ENV=development

# ==================================================
# API GATEWAY
# ==================================================
API_GATEWAY_PORT=8080

AUTH_SERVICE_URL=http://auth-service:8001
USER_SERVICE_URL=http://user-service:8002
CONTENT_SERVICE_URL=http://content-service:8003
CODE_JUDGE_SERVICE_URL=http://code-judge-service:8004
NOTIFICATION_SERVICE_URL=http://notification-service:8005
CHAT_SERVICE_URL=http://chat-service:8006

# ==================================================
# SERVICES PORT
# ==================================================
AUTH_SERVICE_PORT=8001
USER_SERVICE_PORT=8002
CONTENT_SERVICE_PORT=8003
CODE_JUDGE_SERVICE_PORT=8004
NOTIFICATION_SERVICE_PORT=8005
CHAT_SERVICE_PORT=8006

# ==================================================
# AUTH / SECURITY
# ==================================================
JWT_SECRET=dev_jwt_secret_key
JWT_EXPIRES_IN=1d
REFRESH_TOKEN_SECRET=dev_refresh_secret_key
REFRESH_TOKEN_EXPIRES_IN=7d
PASSWORD_SALT_ROUNDS=10

# ==================================================
# MESSAGE BROKER (RabbitMQ)
# ==================================================
RABBITMQ_HOST=message-broker
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_URL=amqp://guest:guest@message-broker:5672

# ==================================================
# DATABASE - POSTGRESQL (AUTH / USER / CONTENT)
# ==================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin

AUTH_DB_NAME=auth_db
USER_DB_NAME=user_db
CONTENT_DB_NAME=content_db

# ==================================================
# CHAT SERVICE - MONGODB
# ==================================================
CHAT_MONGO_HOST=mongo
CHAT_MONGO_PORT=27017
CHAT_MONGO_DB=chat_db
CHAT_MONGO_URL=mongodb://mongo:27017/chat_db

# ==================================================
# REDIS (CACHE / SESSION / SOCKET)
# ==================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ==================================================
# NOTIFICATION SERVICE
# ==================================================
NOTIFICATION_RETRY_LIMIT=5

# ==================================================
# EMAIL (SMTP)
# ==================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password
EMAIL_FROM="IT Social Platform <no-reply@itsocial.com>"

# ==================================================
# CODE JUDGE SERVICE
# ==================================================
CODE_JUDGE_TIMEOUT=5000
CODE_JUDGE_MEMORY_LIMIT=256
CODE_JUDGE_CPU_LIMIT=1

# ==================================================
# SOCKET / REALTIME
# ==================================================
SOCKET_CORS_ORIGIN=http://localhost:3000
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000

# ==================================================
# FRONTEND
# ==================================================
FRONTEND_PORT=3000
REACT_APP_API_BASE_URL=http://localhost:8080
