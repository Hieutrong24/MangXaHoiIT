PORT=4000
NODE_ENV=development

# broker
BROKER_DRIVER=inmemory
# BROKER_DRIVER=rabbitmq
RABBIT_URL=amqp://localhost:5672
RABBIT_EXCHANGE=events
RABBIT_QUEUE=notification-service
RABBIT_PREFETCH=10

# SMTP
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@local

 
WS_ENABLED=false
WS_URL=http://localhost:3000
WS_EVENT_NAME=notify
